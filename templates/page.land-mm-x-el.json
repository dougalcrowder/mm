    "single_title_and_text_DX763f": {
      "type": "single-title_and_text",
      "settings": {
        "title": "A Celebration of Print",
        "text": "<p>We are delighted to present a special collaboration between Molly Mahon and the iconic beauty brand Estée Lauder.</p><p>Molly Mahon is a British printmaker known for her joyful hand block printed designs, rooted in traditional craftsmanship and a distinctive use of colour and pattern. Her work celebrates the beauty of the handmade - a natural pairing with Estée Lauder’s legacy of timeless elegance.</p><p>For this collaboration, Molly has brought her signature wood block prints to a limited collection of gift boxes and cosmetic bags, inspired by some of her most loved designs.</p>",
        "font_type": "body",
        "vertical_alignment": "center",
        "alignment": "center",
        "color_scheme": "dark_text",
        "margin_top": "none",
        "margin_bot": "none"
      }
    },
