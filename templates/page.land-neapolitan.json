    "single_title_and_text_DX763f": {
      "type": "single-title_and_text",
      "settings": {
        "title": "Bring Joy to Your Summer Gatherings",
        "text": "<p>There’s something wonderfully nostalgic about summer entertaining - tables layered beneath the trees, garden lunches that drift into evening, bowls of fruit catching the late afternoon light and the joyful gathering of family and friends around beautifully dressed tables.</p><p>Our new <a href=\"/collections/neapolitan\" target=\"_blank\" title=\"Neapolitan\">Neapolitan</a> Summer Dining Collection was created with exactly these moments in mind. A subtle nod to the creative gatherings, indoor picnics and lives lived between cultivated gardens and grand country houses by the <a href=\"https://www.charleston.org.uk/\" target=\"_blank\" title=\"https://www.charleston.org.uk/\">Bloomsbury Group.</a></p>",
        "font_type": "body",
        "vertical_alignment": "center",
        "alignment": "center",
        "color_scheme": "dark_text",
        "margin_top": "none",
        "margin_bot": "none"
      }
    },
    "image_with_text_te9dAH": {
      "type": "image-with-text",
      "blocks": {
        "heading_bJ9Xtj": {
          "type": "heading",
          "settings": {
            "heading": "A Garden Setting Full of Romance"
          }
        },
        "text_C9PDKk": {
          "type": "text",
          "settings": {
            "text": "<p>The collection was photographed at <a href=\"https://www.clintonlodgegardens.co.uk/home/index.htm\" target=\"_blank\" title=\"https://www.clintonlodgegardens.co.uk/home/index.htm\">Clinton Lodge Gardens</a>, a remarkable private garden lovingly created and maintained over the last 50 years by Lady Collum. </p><p>Filled with architectural hedges, shaded walkways and abundant seasonal planting, the garden provided the perfect backdrop for the collection’s romantic, high-summer mood.</p><p>It was a real privilege to photograph our <a href=\"/collections/neapolitan\" title=\"Neapolitan\">Neapolitan</a> range in such a beautiful setting, bringing each tablescape to life through a series of outdoor lunch scenes throughout the garden.</p><p></p>",
            "code": ""
          }
        },
