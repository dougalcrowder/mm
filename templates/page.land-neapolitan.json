    "single_title_and_text_CnbJrK": {
      "type": "single-title_and_text",
      "name": "Title and Text",
      "settings": {
        "title": "A Garden Setting Full of Romance",
        "text": "<p>The collection was photographed at Clinton Lodge, a remarkable private garden lovingly created and maintained over the last 50 years by Lady Calder. Filled with architectural hedges, shaded walkways and abundant seasonal planting, the garden provided the perfect backdrop for the collection’s romantic, high-summer mood.</p><p>Towering blue delphiniums - recently celebrated in House & Garden’s ongoing feature on old-fashioned plants - were paired with the Luna tablecloth and Peony Urn runner. Their blue tones looked especially striking against the soft plaster-pink walls of the Italian garden pool house, creating a table full of colour and character.</p><p></p>",
        "font_type": "body",
        "vertical_alignment": "center",
        "alignment": "center",
        "color_scheme": "dark_text",
        "margin_top": "none",
        "margin_bot": "m"
      }
    },
