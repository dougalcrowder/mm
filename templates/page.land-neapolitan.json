    "single_title_and_text_DX763f": {
      "type": "single-title_and_text",
      "settings": {
        "title": "Bring Joy to Your Summer Gatherings",
        "text": "<p>There’s something wonderfully nostalgic about summer entertaining - tables layered beneath the trees, garden lunches that drift into evening, bowls of fruit catching the late afternoon light and the joyful gathering of family and friends around beautifully dressed tables.</p><p>Our new <a href=\"/collections/neapolitan\" target=\"_blank\" title=\"Neapolitan\"><strong>Neapolitan</strong></a> Summer Dining Collection was created with exactly these moments in mind.</p>",
        "font_type": "body",
        "vertical_alignment": "center",
        "alignment": "center",
        "color_scheme": "dark_text",
        "margin_top": "none",
        "margin_bot": "none"
      }
    },
    "image_with_text_NPCjCk": {
